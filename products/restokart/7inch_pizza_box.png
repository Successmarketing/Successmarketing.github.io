<div class="login-modal-div">
  <div class="modal-content">
    <div class="close-div"><span class="close">&times;</span></div>
    <div class="white-bg center modal-header">
      <div class="login-register-div">
        <input id="tab1" type="radio" name="tabs" checked>
        <label class="tab-label" for="tab1">Sign In</label>
      
        <input id="tab2" type="radio" name="tabs">
        <label class="tab-label" for="tab2">Sign Up</label>

		
        <section id="content1">
          <form method="POST" class="login-form" id="Login11" autocomplete="off">
            <input type="hidden" name="reqType" value="Login">
            <div class="modal-form-group text-center">
              <div class="loginfailed_login"></div>
            </div>
            <div class="modal-form-group">
              <i class="input-icon fas fa-envelope"></i>
              <input autocomplete="false" name="user" id="loginemail" required="required" type="text" class="modal-form-input" placeholder="E-mail">
            </div>
            <div class="modal-form-group">
              <i class="input-icon fas fa-lock"></i>
              <input autocomplete="false" name="pass" id="loginpassword" type="password" required="required" class="modal-form-input" placeholder="Password">
            </div>
            
		
           
			
            <button class="btn btn-green signin-button" type="submit">Sign In</button>
            <div class="left">
               <a href="https://www.restokart.com/account/recovery"  class="">Forgot Password?</a>
            </div>
          </form>
        </section>
		
		
		  
		
        <section id="content2">
          <form method="POST" class="register-form" id="register-viva" autocomplete="off">
            <input type="hidden" name="reqType" value="Register">
            <div class="modal-form-group">
                   <div class="registration_error"></div>
            </div>
               <div class="modal-form-group">
              <i class="input-icon fas fa-user"></i>
              <input name="name" id="reg-name" type="text" required="required" class="modal-form-input" placeholder="Full Name">
            </div>
            <div class="modal-form-group">
              <i class="input-icon fas fa-envelope"></i>
              <input name="email" id="reg-email" type="email" required="required" class="modal-form-input" placeholder="E-mail">
            </div>
            <div class="modal-form-group">
              <i class="input-icon fas fa-lock"></i>
              <input name="pass" id="reg-password" type="password" required="required" class="modal-form-input" placeholder="Password">
            </div>
            <div class="modal-form-group">
               <i class="input-icon fas fa-phone"></i>
              <input name="phone" id="reg-phone" required="required" type="text" class="modal-form-input typeahead" placeholder="Phone"  maxlength="11" minlength="10" oninput="this.value = this.value.replace(/[^0-9.]/g, ''); this.value = this.value.replace(/(\..*)\./g, '$1');">
            </div>
            
            <div class="modal-form-group">
               <i class="input-icon fas fa-bars"></i>
              <input name="trade" id="reg-trade" type="text" class="modal-form-input" placeholder="Trade Name (Optional)">
            </div>
            
            
            <div class="modal-form-group">
               <i class="input-icon fas fa-university"></i>
              <input name="gst" id="reg-gst" type="text" class="modal-form-input" placeholder="GST No (Optional)" maxlength="16" minlength="14">
            </div>
            
            
            
            <div class="modal-form-group">
              <center><div id="registerCaptcha"></div></center>
            </div>
            <button class="btn btn-green signup-button" id="reg-submit" type="submit">Sign Up</button>
          </form>
        </section>
		
		
